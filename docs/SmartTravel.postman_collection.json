{
  "info": {
    "name": "Smart Travel Website API",
    "_postman_id": "26c430e2-8d5d-4fc1-b3be-8d548f47ed31",
    "description": "Core API collection for Smart Travel Website FYP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "auth", "login" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Places - Nearby",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/places/nearby?lat=28.2096&lng=83.9856&type=restaurant&radius=3000",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "places", "nearby" ],
          "query": [
            { "key": "lat", "value": "28.2096" },
            { "key": "lng", "value": "83.9856" },
            { "key": "type", "value": "restaurant" },
            { "key": "radius", "value": "3000" }
          ]
        }
      }
    },
    {
      "name": "Itinerary - Generate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/itineraries/generate",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "itineraries", "generate" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"destination\": \"Pokhara\",\n  \"budget\": 15000,\n  \"durationDays\": 3,\n  \"interests\": [\"food\", \"nature\", \"boating\"]\n}"
        }
      }
    },
    {
      "name": "Booking - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/bookings",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "bookings" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"locationId\": \"{{locationId}}\",\n  \"date\": \"2026-04-18\",\n  \"amount\": 5000,\n  \"notes\": \"2 guests near Lakeside\"\n}"
        }
      }
    },
    {
      "name": "Payment - Initiate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payments/initiate",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "payments", "initiate" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"provider\": \"khalti\"\n}"
        }
      }
    },
    {
      "name": "Payment - Verify",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payments/verify",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "payments", "verify" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"success\": true\n}"
        }
      }
    },
    {
      "name": "Notifications - Mine",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notifications/me",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "notifications", "me" ]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "token", "value": "" },
    { "key": "locationId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "paymentId", "value": "" }
  ]
}
